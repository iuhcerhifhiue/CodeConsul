{
  "name": "User",
  "type": "object",
  "properties": {
    "role": {
      "type": "string",
      "description": "The role of the user in the app",
      "enum": [
        "admin",
        "user"
      ]
    },
    "plan": {
      "type": "string",
      "description": "The user's subscription plan determining available agents",
      "enum": [
        "free",
        "starter",
        "pro",
        "builder"
      ],
      "default": "free"
    }
  },
  "required": [
    "role"
  ]
}